#!/usr/bin/env bash
# doctor — read-only health check across system + dev environment.

# shellcheck source=/dev/null disable=SC2329  # step funcs run indirectly via dashlib run_step
source ~/.local/share/dashlib/dashlib.sh
dash_init "SYS.DOCTOR" "DIAGNOSTICS"

do_disk_free() {
  local pct; pct=$(df -h / | awk 'NR==2 {gsub("%",""); print $5}')
  local free; free=$(df -h / | awk 'NR==2 {print $4}')
  echo "root: ${pct}% used, $free free"
  if (( pct > 90 )); then set_result "${pct}% USED"; return 1
  else set_result "$free free"; fi
}

do_memory_pressure() {
  if ! have memory_pressure; then set_result "N/A"; return 2; fi
  local pct; pct=$(memory_pressure 2>/dev/null | awk -F: '/percentage/ {gsub("%",""); print $2; exit}' | tr -d ' ')
  echo "free pages: ${pct}%"
  if [[ -z "$pct" ]]; then set_result "?"; return 0
  elif (( pct < 10 )); then set_result "${pct}% LOW"; return 1
  else set_result "${pct}% free"; fi
}

do_swap() {
  local out; out=$(sysctl -n vm.swapusage 2>/dev/null)
  echo "$out"
  local used; used=$(printf '%s' "$out" | grep -Eo 'used = [0-9.]+[KMG]' | awk '{print $3}')
  set_result "${used:-?} used"
}

do_internet() {
  # Try multiple endpoints; tolerate VPN routing oddities.
  local ep
  for ep in https://1.1.1.1 https://www.google.com https://cloudflare.com; do
    if curl -fsSL --max-time 4 -o /dev/null "$ep" 2>/dev/null; then
      set_result "reachable"
      echo "internet OK via $ep"
      return 0
    fi
  done
  set_result "UNREACHABLE"; return 1
}

do_dns() {
  if dig +short +time=2 +tries=1 cloudflare.com >/dev/null 2>&1; then
    set_result "resolving"; echo "dns OK"
  else
    set_result "FAILING"; return 1
  fi
}

do_vpn() {
  local up
  up=$(ifconfig 2>/dev/null | grep -cE '^utun[0-9]+:')
  if (( up > 0 )); then
    echo "$up utun interface(s) up"
    set_result "$up tun up"
  else
    set_result "none"
  fi
}

do_battery_health() {
  if ! have system_profiler; then set_result "N/A"; return 2; fi
  local cycles cond
  cycles=$(system_profiler SPPowerDataType 2>/dev/null | awk -F: '/Cycle Count/ {gsub(/ /,"",$2); print $2; exit}')
  cond=$(system_profiler SPPowerDataType 2>/dev/null | awk -F: '/Condition/ {gsub(/^ +/,"",$2); print $2; exit}')
  echo "cycles=$cycles  condition=$cond"
  # Report cycles regardless; only fail if explicitly "Service Battery" (replace soon).
  if [[ "$cond" == "Service Battery" ]]; then
    set_result "REPLACE ${cycles}c"; return 1
  elif [[ "$cond" == "Service Recommended" ]]; then
    set_result "WARN ${cycles}c"   # show but don't fail
  else
    set_result "${cycles}c ${cond:0:6}"
  fi
}

do_xcode_path() {
  if ! have xcode-select; then set_result "N/A"; return 2; fi
  local p; p=$(xcode-select -p 2>/dev/null)
  echo "$p"
  if [[ -d "$p" ]]; then set_result "OK"; else set_result "MISSING"; return 2; fi
}

do_node() {
  if ! have node; then set_result "NOT INSTALLED"; return 2; fi
  local v; v=$(node -v 2>/dev/null)
  set_result "$v"
}

do_python() {
  if ! have python3; then set_result "NOT INSTALLED"; return 2; fi
  local v; v=$(python3 --version 2>&1 | awk '{print $2}')
  set_result "$v"
}

do_go() {
  if ! have go; then set_result "NOT INSTALLED"; return 2; fi
  local v; v=$(go version | awk '{print $3}')
  set_result "$v"
}

do_rust() {
  if ! have rustc; then set_result "NOT INSTALLED"; return 2; fi
  local v; v=$(rustc --version | awk '{print $2}')
  set_result "$v"
}

do_git() {
  if ! have git; then set_result "NOT INSTALLED"; return 2; fi
  local v; v=$(git --version | awk '{print $3}')
  set_result "$v"
}

do_brew_doctor() {
  if ! have brew; then set_result "NO BREW"; return 2; fi
  local out; out=$(brew doctor 2>&1)
  echo "$out"
  if printf '%s' "$out" | grep -q "Your system is ready to brew"; then
    set_result "ready"
  else
    local warnings; warnings=$(printf '%s' "$out" | grep -c '^Warning:')
    # Brew warnings are usually informational, not failures.
    set_result "${warnings} warn"
    return 0
  fi
}

do_time_sync() {
  local out; out=$(sntp -t 2 time.apple.com 2>&1 | tail -1)
  echo "$out"
  set_result "synced"
}

do_dotfiles() {
  local repo
  for cand in "$HOME/.dotfiles" "$HOME/dotfiles" "$HOME/.config/dotfiles"; do
    if [[ -d "$cand/.git" ]]; then repo="$cand"; break; fi
  done
  [[ -z "${repo:-}" ]] && { set_result "NO REPO"; return 2; }
  cd "$repo" || return 1
  local dirty; dirty=$(git status --porcelain | wc -l | tr -d ' ')
  if (( dirty > 0 )); then set_result "${dirty} dirty"; return 1
  else set_result "clean"; fi
}

add_step "DISK.FREE"       do_disk_free
add_step "MEM.PRESSURE"    do_memory_pressure
add_step "SWAP.USAGE"      do_swap
add_step "NET.INTERNET"    do_internet
add_step "NET.DNS"         do_dns
add_step "NET.VPN"         do_vpn
add_step "BATTERY.HEALTH"  do_battery_health
add_step "TIME.SYNC"       do_time_sync
add_step "XCODE.PATH"      do_xcode_path
add_step "NODE.VERSION"    do_node
add_step "PYTHON.VERSION"  do_python
add_step "GO.VERSION"      do_go
add_step "RUST.VERSION"    do_rust
add_step "GIT.VERSION"     do_git
add_step "BREW.DOCTOR"     do_brew_doctor
add_step "DOTFILES.STATUS" do_dotfiles

dash_run
dash_summary ">> DIAGNOSIS COMPLETE <<"
exit "$FAILED"
