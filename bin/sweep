#!/usr/bin/env bash
# sweep — reclaim disk space across caches.
# Skips ~/Downloads per user preference.

# shellcheck source=/dev/null disable=SC2329  # step funcs run indirectly via dashlib run_step
source ~/.local/share/dashlib/dashlib.sh
dash_init "DISK.SWEEP" "PURGE"

# Capture free disk before/after
DISK_BEFORE=0
DISK_AFTER=0

free_kb() { df -k / | awk 'NR==2 {print $4}'; }

# Each step prints what it did and sets STEP_RESULT to bytes-freed estimate.
size_of() { du -sk "$@" 2>/dev/null | awk '{s+=$1} END {print s+0}'; }

do_pip_cache() {
  if ! have pip; then set_result "NO PIP"; return 2; fi
  local before; before=$(size_of "$HOME/Library/Caches/pip" "$HOME/.cache/pip" 2>/dev/null)
  pip cache purge 2>/dev/null || true
  local after; after=$(size_of "$HOME/Library/Caches/pip" "$HOME/.cache/pip" 2>/dev/null)
  local freed=$(( (before - after) * 1024 ))
  (( freed < 0 )) && freed=0
  set_result "freed $(fmt_bytes "$freed")"
  echo "pip cache: $(fmt_bytes "$freed") freed"
}

do_npm_cache() {
  if ! have npm; then set_result "NO NPM"; return 2; fi
  local before; before=$(size_of "$HOME/.npm" 2>/dev/null)
  npm cache clean --force 2>/dev/null || true
  local after; after=$(size_of "$HOME/.npm" 2>/dev/null)
  local freed=$(( (before - after) * 1024 ))
  (( freed < 0 )) && freed=0
  set_result "freed $(fmt_bytes "$freed")"
  echo "npm cache: $(fmt_bytes "$freed") freed"
}

do_yarn_cache() {
  if ! have yarn; then set_result "NO YARN"; return 2; fi
  local before; before=$(yarn cache dir 2>/dev/null | head -1 | xargs -I{} du -sk {} 2>/dev/null | awk '{print $1}')
  before=${before:-0}
  yarn cache clean 2>/dev/null || true
  set_result "cleaned"
  echo "yarn cache cleaned"
}

do_brew_cleanup() {
  if ! have brew; then set_result "NO BREW"; return 2; fi
  local out; out=$(brew cleanup -s 2>&1)
  echo "$out"
  local freed; freed=$(printf '%s' "$out" | grep -Eo 'This operation has freed [0-9.]+[KMG]B' | tail -1 | grep -Eo '[0-9.]+[KMG]B')
  set_result "freed ${freed:-?}"
}

do_docker_prune() {
  if ! have docker; then set_result "NO DOCKER"; return 2; fi
  if ! docker info >/dev/null 2>&1; then set_result "not running"; return 0; fi
  local out; out=$(docker system prune -f 2>&1)
  echo "$out"
  local freed; freed=$(printf '%s' "$out" | grep -Eo 'Total reclaimed space: [0-9.]+[KMG]?B' | grep -Eo '[0-9.]+[KMG]?B$')
  set_result "freed ${freed:-0B}"
}

do_xcode_derived() {
  local dir="$HOME/Library/Developer/Xcode/DerivedData"
  [[ -d "$dir" ]] || { set_result "NO XCODE"; return 2; }
  local before; before=$(size_of "$dir")
  rm -rf "${dir:?}"/* 2>/dev/null || true
  local freed=$(( before * 1024 ))
  set_result "freed $(fmt_bytes "$freed")"
  echo "xcode derived: $(fmt_bytes "$freed") freed"
}

do_simulator_caches() {
  local dir="$HOME/Library/Developer/CoreSimulator/Caches"
  [[ -d "$dir" ]] || { set_result "NO SIMS"; return 2; }
  local before; before=$(size_of "$dir")
  rm -rf "${dir:?}"/* 2>/dev/null || true
  local freed=$(( before * 1024 ))
  set_result "freed $(fmt_bytes "$freed")"
  echo "sim caches: $(fmt_bytes "$freed") freed"
}

do_gradle_cache() {
  local dir="$HOME/.gradle/caches"
  [[ -d "$dir" ]] || { set_result "NO GRADLE"; return 2; }
  local before; before=$(size_of "$dir")
  # only prune build-cache, not the whole thing
  rm -rf "$dir/build-cache-1" 2>/dev/null || true
  local after; after=$(size_of "$dir")
  local freed=$(( (before - after) * 1024 ))
  (( freed < 0 )) && freed=0
  set_result "freed $(fmt_bytes "$freed")"
}

do_user_caches() {
  local dir="$HOME/Library/Caches"
  [[ -d "$dir" ]] || { set_result "N/A"; return 2; }
  local before; before=$(size_of "$dir")
  # Only delete items modified >7 days ago to be safe.
  find "$dir" -mindepth 2 -type f -mtime +7 -delete 2>/dev/null
  local after; after=$(size_of "$dir")
  local freed=$(( (before - after) * 1024 ))
  (( freed < 0 )) && freed=0
  set_result "freed $(fmt_bytes "$freed")"
  echo "user caches: $(fmt_bytes "$freed") freed (files >7d)"
}

do_trash() {
  local dir="$HOME/.Trash"
  [[ -d "$dir" ]] || { set_result "N/A"; return 2; }
  local before; before=$(size_of "$dir")
  rm -rf "${dir:?}"/* "${dir:?}"/.[!.]* 2>/dev/null
  local freed=$(( before * 1024 ))
  set_result "freed $(fmt_bytes "$freed")"
  echo "trash: $(fmt_bytes "$freed") freed"
}

DISK_BEFORE=$(free_kb)

add_step "PIP.CACHE"        do_pip_cache
add_step "NPM.CACHE"        do_npm_cache
add_step "YARN.CACHE"       do_yarn_cache
add_step "BREW.CLEANUP"     do_brew_cleanup
add_step "DOCKER.PRUNE"     do_docker_prune
add_step "XCODE.DERIVED"    do_xcode_derived
add_step "SIM.CACHES"       do_simulator_caches
add_step "GRADLE.CACHE"     do_gradle_cache
add_step "USER.CACHES"      do_user_caches
add_step "TRASH.EMPTY"      do_trash

dash_run

DISK_AFTER=$(free_kb)
TOTAL_FREED_KB=$(( DISK_AFTER - DISK_BEFORE ))
(( TOTAL_FREED_KB < 0 )) && TOTAL_FREED_KB=0
TOTAL_FREED_BYTES=$(( TOTAL_FREED_KB * 1024 ))

printf '  %sTOTAL RECLAIMED:%s %s%s%s\n' "$BOLD$GREEN" "$RESET" "$BOLD$YELLOW" "$(fmt_bytes "$TOTAL_FREED_BYTES")" "$RESET"

dash_summary ">> SWEEP COMPLETE <<"
exit "$FAILED"
