#!/usr/bin/env bash
# focus ‚ÄĒ pomodoro with hacker UI.
# usage: focus [DURATION]   e.g. focus 25m   focus 90s   focus 1h
#        focus              defaults to 25m

set -u

ARG="${1:-25m}"

# Parse duration to seconds
parse_dur() {
  local s="$1"
  local n unit
  if [[ "$s" =~ ^([0-9]+)([smhSMH]?)$ ]]; then
    n="${BASH_REMATCH[1]}"
    unit=$(printf '%s' "${BASH_REMATCH[2]}" | tr '[:upper:]' '[:lower:]')
    case "$unit" in
      s|"") echo "$n" ;;
      m)    echo $((n * 60)) ;;
      h)    echo $((n * 3600)) ;;
    esac
  else
    echo 1500
  fi
}

TOTAL=$(parse_dur "$ARG")

# Colors
if [[ -t 1 ]]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'
  GREEN=$'\033[32m'; RED=$'\033[31m'; YELLOW=$'\033[33m'; CYAN=$'\033[36m'
else
  BOLD=""; DIM=""; RESET=""; GREEN=""; RED=""; YELLOW=""; CYAN=""
fi

# Big-digit blocks 5-tall (each digit 3 wide). Returns the row-th line.
# Args: digit_char row_index (0..4)
digit_row() {
  local c="$1" r="$2"
  case "$c$r" in
    "00") echo "‚Ėą‚Ėą‚Ėą" ;; "01") echo "‚Ėą ‚Ėą" ;; "02") echo "‚Ėą ‚Ėą" ;; "03") echo "‚Ėą ‚Ėą" ;; "04") echo "‚Ėą‚Ėą‚Ėą" ;;
    "10") echo "  ‚Ėą" ;; "11") echo "  ‚Ėą" ;; "12") echo "  ‚Ėą" ;; "13") echo "  ‚Ėą" ;; "14") echo "  ‚Ėą" ;;
    "20") echo "‚Ėą‚Ėą‚Ėą" ;; "21") echo "  ‚Ėą" ;; "22") echo "‚Ėą‚Ėą‚Ėą" ;; "23") echo "‚Ėą  " ;; "24") echo "‚Ėą‚Ėą‚Ėą" ;;
    "30") echo "‚Ėą‚Ėą‚Ėą" ;; "31") echo "  ‚Ėą" ;; "32") echo "‚Ėą‚Ėą‚Ėą" ;; "33") echo "  ‚Ėą" ;; "34") echo "‚Ėą‚Ėą‚Ėą" ;;
    "40") echo "‚Ėą ‚Ėą" ;; "41") echo "‚Ėą ‚Ėą" ;; "42") echo "‚Ėą‚Ėą‚Ėą" ;; "43") echo "  ‚Ėą" ;; "44") echo "  ‚Ėą" ;;
    "50") echo "‚Ėą‚Ėą‚Ėą" ;; "51") echo "‚Ėą  " ;; "52") echo "‚Ėą‚Ėą‚Ėą" ;; "53") echo "  ‚Ėą" ;; "54") echo "‚Ėą‚Ėą‚Ėą" ;;
    "60") echo "‚Ėą‚Ėą‚Ėą" ;; "61") echo "‚Ėą  " ;; "62") echo "‚Ėą‚Ėą‚Ėą" ;; "63") echo "‚Ėą ‚Ėą" ;; "64") echo "‚Ėą‚Ėą‚Ėą" ;;
    "70") echo "‚Ėą‚Ėą‚Ėą" ;; "71") echo "  ‚Ėą" ;; "72") echo "  ‚Ėą" ;; "73") echo "  ‚Ėą" ;; "74") echo "  ‚Ėą" ;;
    "80") echo "‚Ėą‚Ėą‚Ėą" ;; "81") echo "‚Ėą ‚Ėą" ;; "82") echo "‚Ėą‚Ėą‚Ėą" ;; "83") echo "‚Ėą ‚Ėą" ;; "84") echo "‚Ėą‚Ėą‚Ėą" ;;
    "90") echo "‚Ėą‚Ėą‚Ėą" ;; "91") echo "‚Ėą ‚Ėą" ;; "92") echo "‚Ėą‚Ėą‚Ėą" ;; "93") echo "  ‚Ėą" ;; "94") echo "‚Ėą‚Ėą‚Ėą" ;;
    ":0") echo "   " ;; ":1") echo " ‚Ėą " ;; ":2") echo "   " ;; ":3") echo " ‚Ėą " ;; ":4") echo "   " ;;
    *)    echo "   " ;;
  esac
}

# Print MM:SS as 5-row big text
print_big_time() {
  local mins=$1 secs=$2
  local s
  s=$(printf '%02d:%02d' "$mins" "$secs")
  local r i c row
  for r in 0 1 2 3 4; do
    printf '  '
    for (( i=0; i<${#s}; i++ )); do
      c="${s:$i:1}"
      row=$(digit_row "$c" "$r")
      printf '%s%s%s  ' "$GREEN" "$row" "$RESET"
    done
    printf '\n'
  done
}

# DnD on/off via macOS Shortcuts (user must create shortcuts named "DND On"/"DND Off")
dnd_on()  { have shortcuts && shortcuts run "DND On"  >/dev/null 2>&1 || true; }
dnd_off() { have shortcuts && shortcuts run "DND Off" >/dev/null 2>&1 || true; }
have() { command -v "$1" >/dev/null 2>&1; }

# Slack DnD via API (optional, set SLACK_TOKEN in env)
slack_dnd_on() {
  [[ -n "${SLACK_TOKEN:-}" ]] || return 0
  local mins=$1
  curl -fsSL -X POST -H "Authorization: Bearer $SLACK_TOKEN" \
    "https://slack.com/api/dnd.setSnooze?num_minutes=$mins" >/dev/null 2>&1 || true
}
slack_dnd_off() {
  [[ -n "${SLACK_TOKEN:-}" ]] || return 0
  curl -fsSL -X POST -H "Authorization: Bearer $SLACK_TOKEN" \
    "https://slack.com/api/dnd.endSnooze" >/dev/null 2>&1 || true
}

# Render progress bar across COLS
COLS=$(tput cols 2>/dev/null || echo 80)
BARW=$(( COLS - 16 ))
(( BARW < 20 )) && BARW=20

draw_bar() {
  local pct=$1
  local fill=$(( BARW * pct / 100 ))
  local bar="" i
  for (( i=0; i<fill; i++ )); do bar+="‚Ėą"; done
  for (( i=fill; i<BARW; i++ )); do bar+="‚ĖĎ"; done
  printf '   %s[%s]%s %s%3d%%%s' "$GREEN" "$bar" "$RESET" "$BOLD$GREEN" "$pct" "$RESET"
}

cleanup() {
  tput cnorm 2>/dev/null
  dnd_off
  slack_dnd_off
  printf '\n'
}
trap cleanup EXIT INT TERM

clear
tput civis 2>/dev/null

# Header banner
printf '\n%s' "$GREEN"
cat <<'EOF'
  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
  ‚Ėą‚Ėą‚ēĎ     ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
  ‚ēö‚ēź‚ēĚ      ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
EOF
printf '%s\n' "$RESET"

printf '   %s[ FOCUS.MODE :: target=%ss :: pid=%d ]%s\n\n' "$DIM" "$TOTAL" "$$" "$RESET"

dnd_on
slack_dnd_on $((TOTAL / 60 + 1))

START=$(date +%s)
END=$(( START + TOTAL ))

while :; do
  NOW=$(date +%s)
  REMAIN=$(( END - NOW ))
  (( REMAIN <= 0 )) && break

  MINS=$(( REMAIN / 60 ))
  SECS=$(( REMAIN % 60 ))
  ELAPSED=$(( TOTAL - REMAIN ))
  PCT=$(( ELAPSED * 100 / TOTAL ))

  # Move to top of timer area each tick
  printf '\033[10;1H'
  # Clear 8 lines for timer + bar
  for i in 1 2 3 4 5 6 7 8; do printf '\033[2K\n'; done
  printf '\033[10;1H'

  print_big_time "$MINS" "$SECS"
  printf '\n'
  draw_bar "$PCT"

  sleep 1
done

# Ring the bell
printf '\a\a\a'
clear

# Finale
printf '\n%s%s' "$BOLD" "$GREEN"
cat <<'EOF'
   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
   ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
   ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ
   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
EOF
printf '%s\n' "$RESET"

DUR_FMT=$(printf '%dm%02ds' $((TOTAL/60)) $((TOTAL%60)))
printf '   %s>> FOCUS BLOCK COMPLETE :: %s <<%s\n\n' "$BOLD$YELLOW" "$DUR_FMT" "$RESET"

# Debrief prompt
tput cnorm 2>/dev/null
printf '   %s‚Ü™ debrief (1 line) :%s ' "$DIM" "$RESET"
read -r DEBRIEF
if [[ -n "$DEBRIEF" ]]; then
  mkdir -p "$HOME/.local/state/focus"
  printf '%s | %ss | %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$TOTAL" "$DEBRIEF" \
    >> "$HOME/.local/state/focus/log.txt"
  printf '   %s‚úď logged to ~/.local/state/focus/log.txt%s\n' "$GREEN" "$RESET"
fi
